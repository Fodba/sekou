# ============================================================
#  Maître Sékou — maitresekou.pro
#  URLs propres, redirections 301, HTTPS, cache, compression
# ============================================================

Options -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1) Forcer HTTPS + domaine canonique sans www
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  RewriteRule ^ https://maitresekou.pro%{REQUEST_URI} [L,R=301]

  # 2) Redirections 301 depuis les anciennes URL (ancien site Zyro)
  RewriteRule ^retour-affectif-e-retour-affectif-france/?$            /retour-affectif [L,R=301]
  RewriteRule ^protection-desenvoutement-desenvoutement/?$            /desenvoutement-protection [L,R=301]
  RewriteRule ^contacter-numero-marabout-france-numero-marabout-france/?$ /contact [L,R=301]

  # 2bis) /index.html -> / (accueil canonique)
  RewriteRule ^index\.html$ / [L,R=301]

  # 3) Masquer l'extension .html (redirige /page.html -> /page)
  RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [L,R=301]

  # 4) Servir /page via page.html (sans extension)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# Page d'erreur 404
ErrorDocument 404 /404.html

# ---- Compression ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml application/manifest+json
</IfModule>

# ---- Cache navigateur ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 week"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ---- En-têtes de sécurité légers ----
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
